cat("  Total points plotted:", nrow(plot_data), "\n")
cat("  Chromosomes:", length(chr_levels), "\n")
cat("  MaxEnt_decoy range:", round(min(plot_data$MaxEnt_decoy, na.rm = TRUE), 4), "-",
round(max(plot_data$MaxEnt_decoy, na.rm = TRUE), 4), "\n")
cat("  MaxEnt_decoy mean:", round(mean(plot_data$MaxEnt_decoy, na.rm = TRUE), 4), "\n")
