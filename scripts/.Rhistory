# Create GRanges object for introns
intron_gr <- GRanges(
seqnames = PSI_table_filtered$chr,
ranges = IRanges(start = PSI_table_filtered$start, end = PSI_table_filtered$end),
strand = PSI_table_filtered$strand,
EVENT = PSI_table_filtered$EVENT,
GENE = PSI_table_filtered$GENE
)
# Load decoyIDs_filtered.bed
decoyIDs_filtered <- fread("../data/decoyIDs_filtered.bed",
col.names = c("chr", "start", "end", "decoyID", "score", "strand", "col7")
)
# Drop column 7 (all 1's)
decoyIDs_filtered[, col7 := NULL]
# Extract gene name from decoyID (part before underscore)
decoyIDs_filtered$gene_from_decoyID <- sub("_.*", "", decoyIDs_filtered$decoyID)
cat("Loaded decoyIDs_filtered.bed:", nrow(decoyIDs_filtered), "decoy sites\n")
cat("Unique gene names from decoyIDs:", length(unique(decoyIDs_filtered$gene_from_decoyID)), "\n")
# Create GRanges for decoy sites
decoy_filtered_gr <- GRanges(
seqnames = decoyIDs_filtered$chr,
ranges = IRanges(start = decoyIDs_filtered$start, end = decoyIDs_filtered$end),
decoyID = decoyIDs_filtered$decoyID,
gene_from_decoyID = decoyIDs_filtered$gene_from_decoyID,
strand = decoyIDs_filtered$strand,
score = decoyIDs_filtered$score
)
# Find overlaps between decoy sites and introns (strand-aware matching)
overlaps_filtered <- findOverlaps(decoy_filtered_gr, intron_gr, ignore.strand = FALSE)
cat("Overlaps found (before gene name filtering):", length(overlaps_filtered), "\n")
# Get matched intron coordinates
matched_intron_coords <- data.frame(
decoyID = decoy_filtered_gr$decoyID[queryHits(overlaps_filtered)],
gene_from_decoyID = decoy_filtered_gr$gene_from_decoyID[queryHits(overlaps_filtered)],
intron_chr = seqnames(intron_gr)[subjectHits(overlaps_filtered)],
intron_start = start(intron_gr)[subjectHits(overlaps_filtered)],
intron_end = end(intron_gr)[subjectHits(overlaps_filtered)],
intron_GENE = intron_gr$GENE[subjectHits(overlaps_filtered)],
intron_length = end(intron_gr)[subjectHits(overlaps_filtered)] - start(intron_gr)[subjectHits(overlaps_filtered)],
stringsAsFactors = FALSE
)
cat("Decoy sites overlapping introns (before gene name filtering):", nrow(matched_intron_coords), "\n")
cat("Unique decoys with intron overlaps (before gene name filtering):", length(unique(matched_intron_coords$decoyID)), "\n")
# Filter to only keep matches where gene name from decoyID matches GENE from PSI table
matched_intron_coords <- matched_intron_coords %>%
filter(gene_from_decoyID == intron_GENE)
cat("Decoy sites after gene name matching:", nrow(matched_intron_coords), "\n")
cat("Unique decoys with gene-matched intron overlaps:", length(unique(matched_intron_coords$decoyID)), "\n")
# If a decoy overlaps multiple introns, select the one with the shortest length
matched_intron_coords <- matched_intron_coords %>%
arrange(decoyID, intron_length) %>%
distinct(decoyID, .keep_all = TRUE)
cat("Decoy sites after selecting shortest intron:", nrow(matched_intron_coords), "\n")
# Merge intron coordinates back to decoyIDs_filtered
decoyIDs_filtered <- merge(
decoyIDs_filtered,
matched_intron_coords[, c("decoyID", "intron_chr", "intron_start", "intron_end")],
by = "decoyID",
all.x = TRUE
)
# Remove temporary gene_from_decoyID column
decoyIDs_filtered[, gene_from_decoyID := NULL]
# Update start and end coordinates to full intron coordinates where matches exist
decoyIDs_filtered[!is.na(intron_start), start := intron_start]
decoyIDs_filtered[!is.na(intron_end), end := intron_end]
decoyIDs_filtered[!is.na(intron_chr), chr := intron_chr]
# Remove temporary columns
decoyIDs_filtered[, c("intron_chr", "intron_start", "intron_end") := NULL]
# Count updates
n_updated <- sum(!is.na(matched_intron_coords$decoyID))
cat("Decoys with updated coordinates:", n_updated, "\n")
cat("Decoys without intron matches:", nrow(decoyIDs_filtered) - n_updated, "\n")
# Save updated BED file
output_bed <- "../data/decoyIDs_filtered_intron.bed"
fwrite(
decoyIDs_filtered[, .(chr, start, end, decoyID, score, strand)],
file = output_bed,
sep = "\t",
col.names = FALSE,
quote = FALSE
)
cat("Saved updated BED file to:", output_bed, "\n")
# Load SpliceAI v3.1 data
spliceai_data <- fread("../results/splice_out_v3.1/all_spliceai_scores_v3.1.tsv", sep = "\t", header = TRUE)
# Load phyloP decoy data v3 (merged from decoysv3)
phylop_decoy_v3 <- fread("../results/phyloP/decoysv3/phyloP_decoy_v3_merged.tsv")
# Rename MAF_file to decoyID for consistency
setnames(phylop_decoy_v3, "MAF_file", "decoyID")
# Load PSI table
PSI_table <- fread("../reference/PSI_TABLE-hg38.tab.gz")
# Load decoy coordinates from v3 BED file
decoy_coords <- fread("../data/DecoysInConservedGenes50thpercentilev3.bed",
col.names = c("chr", "start", "end", "decoyID", "score", "strand")
)
cat("Data loaded:\n")
cat("  SpliceAI v3.1 rows:", nrow(spliceai_data), "\n")
cat("  phyloP v3 rows:", nrow(phylop_decoy_v3), "\n")
cat("  PSI table rows:", nrow(PSI_table), "\n")
cat("  Decoy coordinates:", nrow(decoy_coords), "\n")
# Function to parse [max1][pos1][max2][pos2][d] format (v3.1)
parse_score_format <- function(value) {
# Match pattern: [number][number][number][number][number]
match_result <- str_match(value, "\\[([\\d.-]+)\\]\\[(\\d+)\\]\\[([\\d.-]+)\\]\\[(\\d+)\\]\\[([\\d.-]+)\\]")
if (is.na(match_result[1])) {
return(list(max1 = NA, pos1 = NA, max2 = NA, pos2 = NA, d = NA))
}
return(list(
max1 = as.numeric(match_result[2]),
pos1 = as.integer(match_result[3]),
max2 = as.numeric(match_result[4]),
pos2 = as.integer(match_result[5]),
d = as.numeric(match_result[6])
))
}
# Extract decoy IDs
decoy_ids <- spliceai_data$decoyID
# Get species columns (all except decoyID)
species_cols <- setdiff(names(spliceai_data), "decoyID")
# Parse all data into long format
parsed_data_list <- list()
for (species in species_cols) {
parsed_scores <- lapply(spliceai_data[[species]], parse_score_format)
# Convert to data.table
species_data <- data.table(
decoyID = decoy_ids,
species = species,
max1 = sapply(parsed_scores, function(x) x$max1),
pos1 = sapply(parsed_scores, function(x) x$pos1),
max2 = sapply(parsed_scores, function(x) x$max2),
pos2 = sapply(parsed_scores, function(x) x$pos2),
d = sapply(parsed_scores, function(x) x$d)
)
parsed_data_list[[species]] <- species_data
}
# Combine all species data
all_data <- rbindlist(parsed_data_list)
# Filter out -1 values for analysis
all_data_valid <- all_data[max1 != -1.0 & pos1 != -1 & max2 != -1.0 & pos2 != -1]
# Filter to only rows where EVENT starts with "HsaIN"
PSI_table <- PSI_table[grepl("^HsaIN", EVENT), ]
# Remove quality control columns ending in "-Q"
q_cols <- grep("-Q$", colnames(PSI_table), value = TRUE)
if (length(q_cols) > 0) {
PSI_table[, (q_cols) := NULL]
}
# Identify PSI value columns (exclude metadata columns)
metadata_cols <- c("GENE", "EVENT", "COORD", "LENGTH", "FullCO", "COMPLEX")
psi_cols <- setdiff(colnames(PSI_table), metadata_cols)
# Remove rows where >80% of PSI values are NA
na_threshold <- 0.8
if (length(psi_cols) > 0 && nrow(PSI_table) > 0) {
row_na_prop <- rowSums(is.na(PSI_table[, ..psi_cols])) / length(psi_cols)
PSI_table <- PSI_table[row_na_prop <= na_threshold, ]
} else {
stop("No PSI value columns found or table is empty")
}
# Remove columns where >80% of PSI values are NA
if (nrow(PSI_table) > 0 && length(psi_cols) > 0) {
col_na_prop <- colSums(is.na(PSI_table[, ..psi_cols])) / nrow(PSI_table)
cols_to_keep <- names(col_na_prop[col_na_prop <= na_threshold])
psi_cols_filtered <- c(metadata_cols, cols_to_keep)
PSI_table <- PSI_table[, ..psi_cols_filtered]
}
# Create filtered version
PSI_table_filtered <- PSI_table
rm(PSI_table)
gc()
cat("Final PSI table dimensions:", nrow(PSI_table_filtered), "rows x", ncol(PSI_table_filtered), "columns\n")
# Parse COORD column to extract chromosome, start, and end
parse_coord <- function(coord_str) {
# Extract chromosome and coordinates
parts <- strsplit(coord_str, ":")[[1]]
if (length(parts) == 2) {
chr <- parts[1]
coords <- strsplit(parts[2], "-")[[1]]
if (length(coords) == 2) {
start <- as.numeric(coords[1])
end <- as.numeric(coords[2])
return(data.frame(chr = chr, start = start, end = end))
}
}
return(data.frame(chr = NA, start = NA, end = NA))
}
# Apply parsing to all rows
intron_coords <- do.call(rbind, lapply(PSI_table_filtered$COORD, parse_coord))
PSI_table_filtered <- cbind(PSI_table_filtered, intron_coords)
# Extract strand from the last character of FullCO column
PSI_table_filtered$strand <- substr(PSI_table_filtered$FullCO, nchar(PSI_table_filtered$FullCO), nchar(PSI_table_filtered$FullCO))
# Convert to factor and ensure only + or - (handle any edge cases)
PSI_table_filtered$strand <- ifelse(PSI_table_filtered$strand %in% c("+", "-"),
PSI_table_filtered$strand,
NA
)
cat("Strand extracted from FullCO:\n")
cat("  + strand:", sum(PSI_table_filtered$strand == "+", na.rm = TRUE), "\n")
cat("  - strand:", sum(PSI_table_filtered$strand == "-", na.rm = TRUE), "\n")
cat("  Missing/Invalid:", sum(is.na(PSI_table_filtered$strand)), "\n")
# Create GRanges object for introns
intron_gr <- GRanges(
seqnames = PSI_table_filtered$chr,
ranges = IRanges(start = PSI_table_filtered$start, end = PSI_table_filtered$end),
strand = PSI_table_filtered$strand,
EVENT = PSI_table_filtered$EVENT,
GENE = PSI_table_filtered$GENE
)
# Load DecoysControlsUniqueIDsforRecount_filtered.bed (filtered to match decoyIDs_filtered.bed)
decoyIDs_filtered <- fread("../data/DecoysControlsUniqueIDsforRecount_filtered.bed",
col.names = c("chr", "start", "end", "decoyID", "score", "strand")
)
# Extract gene name from decoyID (format: GENE_POSITION_P or GENE_POSITION_C)
# Remove _P or _C suffix, then extract gene (everything before the last underscore and number)
decoyIDs_filtered$decoyID_base <- gsub("_[PC]$", "", decoyIDs_filtered$decoyID)
decoyIDs_filtered$gene_from_decoyID <- stringr::str_replace(decoyIDs_filtered$decoyID_base, "_[0-9]+$", "")
decoyIDs_filtered[, decoyID_base := NULL]
cat("Loaded DecoysControlsUniqueIDsforRecount_filtered.bed:", nrow(decoyIDs_filtered), "decoy sites\n")
cat("Unique gene names from decoyIDs:", length(unique(decoyIDs_filtered$gene_from_decoyID)), "\n")
# Create GRanges for decoy sites
decoy_filtered_gr <- GRanges(
seqnames = decoyIDs_filtered$chr,
