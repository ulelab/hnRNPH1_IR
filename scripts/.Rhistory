)
# Find overlaps between decoy sites and introns (strand-aware matching)
overlaps_filtered <- findOverlaps(decoy_filtered_gr, intron_gr, ignore.strand = FALSE)
cat("Overlaps found (before gene name filtering):", length(overlaps_filtered), "\n")
# Get matched intron coordinates
matched_intron_coords <- data.frame(
decoyID = decoy_filtered_gr$decoyID[queryHits(overlaps_filtered)],
gene_from_decoyID = decoy_filtered_gr$gene_from_decoyID[queryHits(overlaps_filtered)],
intron_chr = seqnames(intron_gr)[subjectHits(overlaps_filtered)],
intron_start = start(intron_gr)[subjectHits(overlaps_filtered)],
intron_end = end(intron_gr)[subjectHits(overlaps_filtered)],
intron_GENE = intron_gr$GENE[subjectHits(overlaps_filtered)],
intron_length = end(intron_gr)[subjectHits(overlaps_filtered)] - start(intron_gr)[subjectHits(overlaps_filtered)],
stringsAsFactors = FALSE
)
cat("Decoy sites overlapping introns (before gene name filtering):", nrow(matched_intron_coords), "\n")
cat("Unique decoys with intron overlaps (before gene name filtering):", length(unique(matched_intron_coords$decoyID)), "\n")
# Filter to only keep matches where gene name from decoyID matches GENE from PSI table
matched_intron_coords <- matched_intron_coords %>%
filter(gene_from_decoyID == intron_GENE)
cat("Decoy sites after gene name matching:", nrow(matched_intron_coords), "\n")
cat("Unique decoys with gene-matched intron overlaps:", length(unique(matched_intron_coords$decoyID)), "\n")
# If a decoy overlaps multiple introns, select the one with the shortest length
matched_intron_coords <- matched_intron_coords %>%
arrange(decoyID, intron_length) %>%
distinct(decoyID, .keep_all = TRUE)
cat("Decoy sites after selecting shortest intron:", nrow(matched_intron_coords), "\n")
# Merge intron coordinates back to decoyIDs_filtered
decoyIDs_filtered <- merge(
decoyIDs_filtered,
matched_intron_coords[, c("decoyID", "intron_chr", "intron_start", "intron_end")],
by = "decoyID",
all.x = TRUE
)
# Remove temporary gene_from_decoyID column
decoyIDs_filtered[, gene_from_decoyID := NULL]
# Update start and end coordinates to full intron coordinates where matches exist
decoyIDs_filtered[!is.na(intron_start), start := intron_start]
decoyIDs_filtered[!is.na(intron_end), end := intron_end]
decoyIDs_filtered[!is.na(intron_chr), chr := intron_chr]
# Remove temporary columns
decoyIDs_filtered[, c("intron_chr", "intron_start", "intron_end") := NULL]
# Count updates
n_updated <- sum(!is.na(matched_intron_coords$decoyID))
cat("Decoys with updated coordinates:", n_updated, "\n")
cat("Decoys without intron matches:", nrow(decoyIDs_filtered) - n_updated, "\n")
# Save updated BED file
output_bed <- "../data/DecoysControlsUniqueIDsforRecount_filtered_intron.bed"
fwrite(
decoyIDs_filtered[, .(chr, start, end, decoyID, score, strand)],
file = output_bed,
sep = "\t",
col.names = FALSE,
quote = FALSE
)
cat("Saved updated BED file to:", output_bed, "\n")
