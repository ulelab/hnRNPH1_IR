stringsAsFactors = FALSE
)
# Calculate overlap length
overlap_protein_coding_df$overlap_length <- pmin(overlap_protein_coding_df$decoy_end, overlap_protein_coding_df$feature_end) -
pmax(overlap_protein_coding_df$decoy_start, overlap_protein_coding_df$feature_start) + 1
cat("Created overlap table with", nrow(overlap_protein_coding_df), "rows\n")
# Summary statistics for protein coding overlaps
cat("Protein Coding Region Overlap Summary:\n")
cat("  Total decoy rows:", length(decoy_gr), "\n")
cat("  Total protein coding features:", length(protein_coding_features), "\n")
cat("  Decoy rows overlapping protein coding regions:", length(unique(queryHits(overlaps_protein_coding))), "\n")
cat("  Total overlap pairs:", nrow(overlap_protein_coding_df), "\n")
cat("  Mean overlap length:", round(mean(overlap_protein_coding_df$overlap_length), 2), "bp\n")
cat("  Median overlap length:", round(median(overlap_protein_coding_df$overlap_length), 2), "bp\n")
cat("\nOverlaps by feature type:\n")
print(table(overlap_protein_coding_df$feature_type))
# Keep only BED rows that overlap any protein coding feature
protein_coding_row_idx <- sort(unique(queryHits(overlaps_protein_coding)))
decoy_protein_coding_bed <- decoy_bed[protein_coding_row_idx, ]
cat("Filtering BED rows to keep only protein coding overlaps...\n")
cat("  Original BED rows:", nrow(decoy_bed), "\n")
cat("  Protein coding BED rows:", nrow(decoy_protein_coding_bed), "\n")
cat("  Removed:", nrow(decoy_bed) - nrow(decoy_protein_coding_bed), "\n")
# View first few overlaps
head(overlap_protein_coding_df, n = 20)
# Save filtered BED rows (protein coding overlaps only)
write.table(decoy_protein_coding_bed,
file = "../data/DecoySpliceSites_proteincoding.bed",
sep = "\t",
quote = FALSE,
row.names = FALSE,
col.names = FALSE)
cat("Filtered BED saved to ../data/DecoySpliceSites_proteincoding.bed\n")
cat("  Rows saved:", nrow(decoy_protein_coding_bed), "\n")
# Also save overlap details
write.table(overlap_protein_coding_df,
file = "../results/decoy_protein_coding_overlaps.tsv",
sep = "\t",
quote = FALSE,
row.names = FALSE)
cat("Overlap details saved to ../results/decoy_protein_coding_overlaps.tsv\n")
knitr::opts_chunk$set(echo = TRUE, warning = FALSE, message = FALSE)
library(GenomicRanges)
library(rtracklayer)
library(dplyr)
# Load DecoySpliceSites_f50.bed file
# BED format: chr, start, end, name, score, strand, extra
decoy_bed <- read.table("../data/DecoySpliceSites_f50.bed",
sep = "\t",
header = FALSE,
stringsAsFactors = FALSE)
# Set column names for BED file
colnames(decoy_bed) <- c("chr", "start", "end", "name", "score", "strand", "extra")
# Convert to 1-based coordinates (BED is 0-based, GenomicRanges uses 1-based)
# Note: BED start is 0-based, end is 1-based, so we add 1 to start
decoy_gr <- GRanges(
seqnames = decoy_bed$chr,
ranges = IRanges(start = decoy_bed$start + 1, end = decoy_bed$end),
strand = decoy_bed$strand,
name = decoy_bed$name,
score = decoy_bed$score
)
cat("Loaded", length(decoy_gr), "decoy ID regions\n")
# Load GTF and keep only features belonging to protein-coding genes.
gtf <- import("../reference/gencode.v49.annotation.gtf.gz", format = "gtf")
exon_gr <- gtf[gtf$type == "exon"]
protein_coding_genes <- gtf[gtf$type == "gene" & gtf$gene_type == "protein_coding"]
protein_coding_gene_ids <- unique(protein_coding_genes$gene_id)
protein_coding_features <- gtf[gtf$gene_id %in% protein_coding_gene_ids]
cat("Loaded", length(gtf), "total GTF features\n")
cat("Found", length(exon_gr), "exon features\n")
cat("Found", length(protein_coding_genes), "protein coding genes\n")
cat("Found", length(protein_coding_features), "features from protein coding genes\n")
cat("  Genes:", sum(protein_coding_features$type == "gene"), "\n")
cat("  Transcripts:", sum(protein_coding_features$type == "transcript"), "\n")
cat("  Exons:", sum(protein_coding_features$type == "exon"), "\n")
# Step 1: keep decoy rows that overlap any exon, regardless of strand.
overlaps_exon_unstranded <- findOverlaps(
query = decoy_gr,
subject = exon_gr,
ignore.strand = TRUE
)
cat("Found", length(overlaps_exon_unstranded), "unstranded overlaps with exons\n")
overlap_exon_unstranded_df <- data.frame(
decoy_name = decoy_gr[queryHits(overlaps_exon_unstranded)]$name,
decoy_chr = seqnames(decoy_gr[queryHits(overlaps_exon_unstranded)]),
decoy_start = start(decoy_gr[queryHits(overlaps_exon_unstranded)]),
decoy_end = end(decoy_gr[queryHits(overlaps_exon_unstranded)]),
decoy_strand = strand(decoy_gr[queryHits(overlaps_exon_unstranded)]),
decoy_score = decoy_gr[queryHits(overlaps_exon_unstranded)]$score,
exon_chr = seqnames(exon_gr[subjectHits(overlaps_exon_unstranded)]),
exon_start = start(exon_gr[subjectHits(overlaps_exon_unstranded)]),
exon_end = end(exon_gr[subjectHits(overlaps_exon_unstranded)]),
exon_strand = strand(exon_gr[subjectHits(overlaps_exon_unstranded)]),
gene_id = exon_gr[subjectHits(overlaps_exon_unstranded)]$gene_id,
gene_name = exon_gr[subjectHits(overlaps_exon_unstranded)]$gene_name,
transcript_id = exon_gr[subjectHits(overlaps_exon_unstranded)]$transcript_id,
exon_number = exon_gr[subjectHits(overlaps_exon_unstranded)]$exon_number,
stringsAsFactors = FALSE
)
overlap_exon_unstranded_df$overlap_length <- pmin(overlap_exon_unstranded_df$decoy_end, overlap_exon_unstranded_df$exon_end) -
pmax(overlap_exon_unstranded_df$decoy_start, overlap_exon_unstranded_df$exon_start) + 1
# Keep strand agreement as a QC field (overlaps are intentionally unstranded).
overlap_exon_unstranded_df$strand_match <- overlap_exon_unstranded_df$decoy_strand == overlap_exon_unstranded_df$exon_strand
cat("Created unstranded exon overlap table with", nrow(overlap_exon_unstranded_df), "rows\n")
cat("Exon Overlap (Unstranded) Summary:\n")
cat("  Total decoy rows:", length(decoy_gr), "\n")
cat("  Total exon features:", length(exon_gr), "\n")
cat("  Decoy rows with exon overlap (unstranded):", length(unique(queryHits(overlaps_exon_unstranded))), "\n")
cat("  Total overlap pairs:", nrow(overlap_exon_unstranded_df), "\n")
cat("  Mean overlap length:", round(mean(overlap_exon_unstranded_df$overlap_length), 2), "bp\n")
cat("  Median overlap length:", round(median(overlap_exon_unstranded_df$overlap_length), 2), "bp\n")
cat("\nStrand agreement among unstranded overlaps (QC only):\n")
cat("  Same strand:", sum(overlap_exon_unstranded_df$strand_match), "\n")
cat("  Opposite strand:", sum(!overlap_exon_unstranded_df$strand_match), "\n")
head(overlap_exon_unstranded_df, n = 20)
# Keep only BED rows overlapping any exon (unstranded).
exon_unstranded_row_idx <- sort(unique(queryHits(overlaps_exon_unstranded)))
decoy_exon_unstranded_bed <- decoy_bed[exon_unstranded_row_idx, ]
decoy_exon_unstranded_gr <- GRanges(
seqnames = decoy_exon_unstranded_bed$chr,
ranges = IRanges(start = decoy_exon_unstranded_bed$start + 1, end = decoy_exon_unstranded_bed$end),
strand = decoy_exon_unstranded_bed$strand,
name = decoy_exon_unstranded_bed$name,
score = decoy_exon_unstranded_bed$score
)
cat("Filtering BED rows to keep exon-overlapping rows (unstranded)...\n")
cat("  Original BED rows:", nrow(decoy_bed), "\n")
cat("  Exon-overlapping BED rows:", nrow(decoy_exon_unstranded_bed), "\n")
cat("  Removed:", nrow(decoy_bed) - nrow(decoy_exon_unstranded_bed), "\n")
# Step 2: from exon-overlapping rows, keep only protein-coding overlaps.
overlaps_protein_coding <- findOverlaps(query = decoy_exon_unstranded_gr,
subject = protein_coding_features,
ignore.strand = FALSE)
cat("Found", length(overlaps_protein_coding), "overlapping pairs with protein coding regions\n")
# Create a data frame with overlap information
overlap_protein_coding_df <- data.frame(
decoy_name = decoy_exon_unstranded_gr[queryHits(overlaps_protein_coding)]$name,
decoy_chr = seqnames(decoy_exon_unstranded_gr[queryHits(overlaps_protein_coding)]),
decoy_start = start(decoy_exon_unstranded_gr[queryHits(overlaps_protein_coding)]),
decoy_end = end(decoy_exon_unstranded_gr[queryHits(overlaps_protein_coding)]),
decoy_strand = strand(decoy_exon_unstranded_gr[queryHits(overlaps_protein_coding)]),
decoy_score = decoy_exon_unstranded_gr[queryHits(overlaps_protein_coding)]$score,
feature_type = protein_coding_features[subjectHits(overlaps_protein_coding)]$type,
feature_chr = seqnames(protein_coding_features[subjectHits(overlaps_protein_coding)]),
feature_start = start(protein_coding_features[subjectHits(overlaps_protein_coding)]),
feature_end = end(protein_coding_features[subjectHits(overlaps_protein_coding)]),
feature_strand = strand(protein_coding_features[subjectHits(overlaps_protein_coding)]),
gene_id = protein_coding_features[subjectHits(overlaps_protein_coding)]$gene_id,
gene_name = protein_coding_features[subjectHits(overlaps_protein_coding)]$gene_name,
gene_type = protein_coding_features[subjectHits(overlaps_protein_coding)]$gene_type,
stringsAsFactors = FALSE
)
# Calculate overlap length
overlap_protein_coding_df$overlap_length <- pmin(overlap_protein_coding_df$decoy_end, overlap_protein_coding_df$feature_end) -
pmax(overlap_protein_coding_df$decoy_start, overlap_protein_coding_df$feature_start) + 1
cat("Created overlap table with", nrow(overlap_protein_coding_df), "rows\n")
# Summary statistics for protein coding overlaps
cat("Protein Coding Region Overlap Summary:\n")
cat("  Total decoy rows:", length(decoy_gr), "\n")
cat("  Exon-overlapping decoy rows (unstranded):", length(decoy_exon_unstranded_gr), "\n")
cat("  Total protein coding features:", length(protein_coding_features), "\n")
cat("  Decoy rows overlapping protein coding regions:", length(unique(queryHits(overlaps_protein_coding))), "\n")
cat("  Total overlap pairs:", nrow(overlap_protein_coding_df), "\n")
cat("  Mean overlap length:", round(mean(overlap_protein_coding_df$overlap_length), 2), "bp\n")
cat("  Median overlap length:", round(median(overlap_protein_coding_df$overlap_length), 2), "bp\n")
cat("\nOverlaps by feature type:\n")
print(table(overlap_protein_coding_df$feature_type))
# Keep only BED rows that overlap any protein coding feature
protein_coding_row_idx <- sort(unique(queryHits(overlaps_protein_coding)))
decoy_protein_coding_bed <- decoy_exon_unstranded_bed[protein_coding_row_idx, ]
cat("Filtering BED rows to keep only protein coding overlaps...\n")
cat("  Input BED rows (after exon unstranded filter):", nrow(decoy_exon_unstranded_bed), "\n")
cat("  Protein coding BED rows:", nrow(decoy_protein_coding_bed), "\n")
cat("  Removed:", nrow(decoy_exon_unstranded_bed) - nrow(decoy_protein_coding_bed), "\n")
# View first few overlaps
head(overlap_protein_coding_df, n = 20)
# Save filtered BED rows (protein coding overlaps only)
write.table(decoy_protein_coding_bed,
file = "../data/DecoySpliceSites_proteincoding.bed",
sep = "\t",
quote = FALSE,
row.names = FALSE,
col.names = FALSE)
cat("Filtered BED saved to ../data/DecoySpliceSites_proteincoding.bed\n")
cat("  Rows saved:", nrow(decoy_protein_coding_bed), "\n")
# Save intermediate exon-unstranded overlap BED
write.table(decoy_exon_unstranded_bed,
file = "../data/DecoySpliceSites_exon_unstranded.bed",
sep = "\t",
quote = FALSE,
row.names = FALSE,
col.names = FALSE)
cat("Intermediate BED saved to ../data/DecoySpliceSites_exon_unstranded.bed\n")
# Also save overlap details
write.table(overlap_protein_coding_df,
file = "../results/decoy_protein_coding_overlaps.tsv",
sep = "\t",
quote = FALSE,
row.names = FALSE)
cat("Overlap details saved to ../results/decoy_protein_coding_overlaps.tsv\n")
write.table(overlap_exon_unstranded_df,
file = "../results/decoy_exon_overlaps_unstranded.tsv",
sep = "\t",
quote = FALSE,
row.names = FALSE)
cat("Unstranded exon overlap details saved to ../results/decoy_exon_overlaps_unstranded.tsv\n")
View(decoy_protein_coding_bed)
knitr::opts_chunk$set(echo = TRUE, warning = FALSE, message = FALSE)
library(GenomicRanges)
library(rtracklayer)
# Load DecoySpliceSites_f50.bed file
# BED format: chr, start, end, name, score, strand, extra
decoy_bed <- read.table("../data/DecoySpliceSites_f50.bed",
sep = "\t",
header = FALSE,
stringsAsFactors = FALSE
)
# Set column names for BED file
colnames(decoy_bed) <- c("chr", "start", "end", "name", "score", "strand", "extra")
# Convert to 1-based coordinates (BED is 0-based, GenomicRanges uses 1-based)
# Note: BED start is 0-based, end is 1-based, so we add 1 to start
decoy_gr <- GRanges(
seqnames = decoy_bed$chr,
ranges = IRanges(start = decoy_bed$start + 1, end = decoy_bed$end),
strand = decoy_bed$strand,
name = decoy_bed$name,
score = decoy_bed$score
)
cat("Loaded", length(decoy_gr), "decoy ID regions\n")
# Load GTF file and filter for exons only
gtf <- import("../reference/gencode.v49.annotation.gtf.gz", format = "gtf")
# Filter for exon features only
exon_gr <- gtf[gtf$type == "exon"]
cat("Loaded", length(exon_gr), "exon regions from GTF\n")
# Find exon overlaps ignoring strand
exon_overlaps <- findOverlaps(
query = decoy_gr,
subject = exon_gr,
ignore.strand = TRUE
)
cat("Found", length(exon_overlaps), "overlap pairs (strand-agnostic)\n")
exon_overlap_df <- data.frame(
decoy_name = decoy_gr[queryHits(exon_overlaps)]$name,
decoy_chr = seqnames(decoy_gr[queryHits(exon_overlaps)]),
decoy_start = start(decoy_gr[queryHits(exon_overlaps)]),
decoy_end = end(decoy_gr[queryHits(exon_overlaps)]),
decoy_strand = strand(decoy_gr[queryHits(exon_overlaps)]),
decoy_score = decoy_gr[queryHits(exon_overlaps)]$score,
exon_chr = seqnames(exon_gr[subjectHits(exon_overlaps)]),
exon_start = start(exon_gr[subjectHits(exon_overlaps)]),
exon_end = end(exon_gr[subjectHits(exon_overlaps)]),
exon_strand = strand(exon_gr[subjectHits(exon_overlaps)]),
gene_id = exon_gr[subjectHits(exon_overlaps)]$gene_id,
gene_name = exon_gr[subjectHits(exon_overlaps)]$gene_name,
transcript_id = exon_gr[subjectHits(exon_overlaps)]$transcript_id,
exon_number = exon_gr[subjectHits(exon_overlaps)]$exon_number,
stringsAsFactors = FALSE
)
exon_overlap_df$overlap_length <- pmin(exon_overlap_df$decoy_end, exon_overlap_df$exon_end) -
pmax(exon_overlap_df$decoy_start, exon_overlap_df$exon_start) + 1
exon_overlap_df$strand_match <- exon_overlap_df$decoy_strand == exon_overlap_df$exon_strand
cat("Created overlap table with", nrow(exon_overlap_df), "rows\n")
cat("Exon Overlap (Unstranded) Summary:\n")
cat("  Total decoy rows:", length(decoy_gr), "\n")
cat("  Total exons:", length(exon_gr), "\n")
cat("  Rows with exon overlaps:", length(unique(queryHits(exon_overlaps))), "\n")
cat("  Total overlap pairs:", nrow(exon_overlap_df), "\n")
cat("  Same strand:", sum(exon_overlap_df$strand_match), "\n")
cat("  Opposite strand:", sum(!exon_overlap_df$strand_match), "\n")
head(exon_overlap_df, n = 20)
write.table(exon_overlap_df,
file = "../results/decoy_exon_overlaps_unstranded.tsv",
sep = "\t",
quote = FALSE,
row.names = FALSE
)
cat("Results saved to ../results/decoy_exon_overlaps_unstranded.tsv\n")
overlapped_idx <- sort(unique(queryHits(exon_overlaps)))
no_unstranded_idx <- setdiff(seq_len(nrow(decoy_bed)), overlapped_idx)
no_unstranded_bed <- decoy_bed[no_unstranded_idx, ]
cat("Created no-unstranded-overlap BED subset\n")
cat("Rows without unstranded exon overlaps:", nrow(no_unstranded_bed), "\n")
# Create GRanges object for no-unstranded-overlap BED rows
no_unstranded_gr <- GRanges(
seqnames = no_unstranded_bed$chr,
ranges = IRanges(start = no_unstranded_bed$start + 1, end = no_unstranded_bed$end),
strand = no_unstranded_bed$strand,
name = no_unstranded_bed$name,
score = no_unstranded_bed$score
)
cat("Created GRanges object with", length(no_unstranded_gr), "no unstranded decoy ID regions\n")
# Filter GTF for protein coding regions
protein_coding_genes <- gtf[gtf$type == "gene" & gtf$gene_type == "protein_coding"]
cat("Found", length(protein_coding_genes), "protein coding genes\n")
# Also get all features (exons, transcripts, etc.) from protein coding genes
protein_coding_gene_ids <- unique(protein_coding_genes$gene_id)
protein_coding_features <- gtf[gtf$gene_id %in% protein_coding_gene_ids]
cat("Found", length(protein_coding_features), "features from protein coding genes\n")
cat("  Genes:", sum(protein_coding_features$type == "gene"), "\n")
cat("  Transcripts:", sum(protein_coding_features$type == "transcript"), "\n")
cat("  Exons:", sum(protein_coding_features$type == "exon"), "\n")
# Find overlaps between no-unstranded BED rows and protein coding regions
overlaps_protein_coding <- findOverlaps(
query = no_unstranded_gr,
subject = protein_coding_features,
ignore.strand = FALSE
)
cat("Found", length(overlaps_protein_coding), "overlapping pairs with protein coding regions\n")
# Create a data frame with overlap information
overlap_protein_coding_df <- data.frame(
decoy_name = no_unstranded_gr[queryHits(overlaps_protein_coding)]$name,
decoy_chr = seqnames(no_unstranded_gr[queryHits(overlaps_protein_coding)]),
decoy_start = start(no_unstranded_gr[queryHits(overlaps_protein_coding)]),
decoy_end = end(no_unstranded_gr[queryHits(overlaps_protein_coding)]),
decoy_strand = strand(no_unstranded_gr[queryHits(overlaps_protein_coding)]),
feature_type = protein_coding_features[subjectHits(overlaps_protein_coding)]$type,
feature_chr = seqnames(protein_coding_features[subjectHits(overlaps_protein_coding)]),
feature_start = start(protein_coding_features[subjectHits(overlaps_protein_coding)]),
feature_end = end(protein_coding_features[subjectHits(overlaps_protein_coding)]),
feature_strand = strand(protein_coding_features[subjectHits(overlaps_protein_coding)]),
gene_id = protein_coding_features[subjectHits(overlaps_protein_coding)]$gene_id,
gene_name = protein_coding_features[subjectHits(overlaps_protein_coding)]$gene_name,
gene_type = protein_coding_features[subjectHits(overlaps_protein_coding)]$gene_type,
stringsAsFactors = FALSE
)
# Calculate overlap length
overlap_protein_coding_df$overlap_length <- pmin(overlap_protein_coding_df$decoy_end, overlap_protein_coding_df$feature_end) -
pmax(overlap_protein_coding_df$decoy_start, overlap_protein_coding_df$feature_start) + 1
cat("Created overlap table with", nrow(overlap_protein_coding_df), "rows\n")
# Summary statistics for protein coding overlaps
cat("Protein Coding Region Overlap Summary:\n")
cat("  Total no unstranded decoy IDs:", length(no_unstranded_gr), "\n")
cat("  Total protein coding features:", length(protein_coding_features), "\n")
cat("  Decoy IDs overlapping protein coding regions:", length(unique(overlap_protein_coding_df$decoy_name)), "\n")
cat("  Total overlap pairs:", nrow(overlap_protein_coding_df), "\n")
cat("\nOverlaps by feature type:\n")
print(table(overlap_protein_coding_df$feature_type))
protein_coding_decoy_ids <- unique(overlap_protein_coding_df$decoy_name)
cat("Filtering BED data to keep only protein coding overlapping loci...\n")
cat("  Decoy IDs overlapping protein coding:", length(protein_coding_decoy_ids), "\n")
cat("  Original rows:", nrow(no_unstranded_bed), "\n")
decoy_protein_coding_bed <- no_unstranded_bed[no_unstranded_bed$name %in% protein_coding_decoy_ids, ]
cat("  Filtered rows:", nrow(decoy_protein_coding_bed), "\n")
cat("  Removed:", nrow(no_unstranded_bed) - nrow(decoy_protein_coding_bed), "\n")
# View first few overlaps
head(overlap_protein_coding_df, n = 20)
# Save filtered BED rows
write.table(decoy_protein_coding_bed,
file = "../data/DecoySpliceSites_proteincoding.bed",
sep = "\t",
quote = FALSE,
row.names = FALSE,
col.names = FALSE
)
cat("Filtered BED saved to ../data/DecoySpliceSites_proteincoding.bed\n")
cat("  Rows saved:", nrow(decoy_protein_coding_bed), "\n")
View(decoy_protein_coding_bed)
