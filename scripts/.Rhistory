# Prepare data for Manhattan plot - filter to top 100 decoys only
plot_data <- final_data %>%
filter(!is.na(MaxEnt_decoy)) %>%
{ if (!is.null(top100_decoys) && length(top100_decoys) > 0) filter(., decoyID %in% top100_decoys) else . } %>%
select(chr, start, end, MaxEnt_decoy, decoyID)
# Order chromosomes (standard order + any non-standard)
chr_order <- c(paste0("chr", c(1:22, "X", "Y", "M")))
chr_levels <- unique(plot_data$chr)
chr_levels <- c(intersect(chr_order, chr_levels), setdiff(chr_levels, chr_order))
plot_data$chr <- factor(plot_data$chr, levels = chr_levels)
# Sort by chromosome and position
plot_data <- plot_data %>%
arrange(chr, start)
# Calculate cumulative positions for Manhattan plot
chr_lengths <- plot_data %>%
group_by(chr) %>%
summarise(max_pos = max(end, na.rm = TRUE), .groups = "drop") %>%
arrange(factor(chr, levels = chr_levels))
# Calculate cumulative start positions for each chromosome
cumulative_pos <- 0
chr_centers <- numeric(length(chr_levels))
names(chr_centers) <- chr_levels
plot_data$cumulative_pos <- NA_real_
for (i in seq_along(chr_levels)) {
chr_name <- chr_levels[i]
chr_data <- plot_data[plot_data$chr == chr_name, ]
if (nrow(chr_data) > 0) {
chr_max_pos <- max(chr_data$end, na.rm = TRUE)
chr_centers[chr_name] <- cumulative_pos + chr_max_pos / 2
# Add positions for this chromosome
plot_data$cumulative_pos[plot_data$chr == chr_name] <-
cumulative_pos + chr_data$start
cumulative_pos <- cumulative_pos + chr_max_pos + max(chr_lengths$max_pos, na.rm = TRUE) * 0.02  # Add small gap between chromosomes
}
}
# Create Manhattan plot with labels for top 100 decoys
p_manhattan <- ggplot(plot_data, aes(x = cumulative_pos, y = MaxEnt_decoy, color = chr)) +
geom_point(alpha = 0.6, size = 0.5) +
geom_text_repel(
aes(label = decoyID),
size = 2.5,
box.padding = unit(0.35, "lines"),
point.padding = unit(0.3, "lines"),
segment.color = 'grey50',
min.segment.length = 0,
max.overlaps = Inf
) +
scale_color_manual(values = rep(c("#1f77b4", "#ff7f0e"), length.out = length(chr_levels))) +
scale_x_continuous(
breaks = chr_centers,
labels = names(chr_centers),
expand = expansion(mult = 0.01)
) +
labs(
title = "Manhattan Plot: MaxEnt Decoy Scores Across Genome (Top 100 phastCons Decoys)",
subtitle = paste("Total decoy sites plotted:", nrow(plot_data)),
x = "Chromosome",
y = "MaxEnt Decoy Score",
color = "Chromosome"
) +
theme_minimal() +
theme(
plot.title = element_text(size = 14, face = "bold"),
plot.subtitle = element_text(size = 12),
axis.text.x = element_text(angle = 45, hjust = 1, size = 8),
axis.text.y = element_text(size = 10),
legend.position = "none",
panel.grid.major.x = element_blank(),
panel.grid.minor.x = element_blank(),
panel.grid.minor.y = element_blank()
)
print(p_manhattan)
# Print summary statistics
