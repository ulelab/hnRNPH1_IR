if (nrow(data_with_phastcons) > 0) {
# Get top 100 for phastCons (470-way) - highest values
top100_phastcons <- data_with_phastcons %>%
arrange(desc(phastCons)) %>%
slice_head(n = 100) %>%
pull(decoyID)
# Get top 100 for phastCons100way - highest values
top100_phastcons100way <- data_with_phastcons %>%
arrange(desc(phastCons100way)) %>%
slice_head(n = 100) %>%
pull(decoyID)
# Find intersection - decoyIDs in top 100 for both
top100_both <- intersect(top100_phastcons, top100_phastcons100way)
cat("\n=== Top 100 for Both phastCons Columns ===\n")
cat("  Total rows with both phastCons values:", nrow(data_with_phastcons), "\n")
cat("  Rows in top 100 for phastCons (470-way):", length(top100_phastcons), "\n")
cat("  Rows in top 100 for phastCons100way:", length(top100_phastcons100way), "\n")
cat("  Rows in top 100 for BOTH:", length(top100_both), "\n\n")
if (length(top100_both) > 0) {
# Get full data for these decoyIDs
top100_both_data <- final_data[final_data$decoyID %in% top100_both, ]
# Sort by phastCons (descending) for display
top100_both_data <- top100_both_data %>%
arrange(desc(phastCons))
cat("=== All Rows in Top 100 for Both phastCons Columns ===\n\n")
print(top100_both_data)
} else {
cat("No rows found in top 100 for both phastCons columns.\n")
}
} else {
cat("\nNo rows with both phastCons values available.\n")
}
# Get top 100 decoys from phastCons analysis (if available)
top100_decoys <- NULL
if (exists("top100_both") && length(top100_both) > 0) {
top100_decoys <- top100_both
} else {
# Fallback: use top 100 by phastCons if top100_both not available
data_with_phastcons_temp <- final_data[!is.na(final_data$phastCons) & !is.na(final_data$phastCons100way), ]
if (nrow(data_with_phastcons_temp) > 0) {
