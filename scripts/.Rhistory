)
# Find overlaps between decoy sites and introns (strand-aware matching)
overlaps_filtered <- findOverlaps(decoy_filtered_gr, intron_gr, ignore.strand = FALSE)
cat("Overlaps found (before gene name filtering):", length(overlaps_filtered), "\n")
# Get matched intron coordinates
matched_intron_coords <- data.frame(
decoyID = decoy_filtered_gr$decoyID[queryHits(overlaps_filtered)],
gene_from_decoyID = decoy_filtered_gr$gene_from_decoyID[queryHits(overlaps_filtered)],
intron_chr = seqnames(intron_gr)[subjectHits(overlaps_filtered)],
intron_start = start(intron_gr)[subjectHits(overlaps_filtered)],
intron_end = end(intron_gr)[subjectHits(overlaps_filtered)],
intron_GENE = intron_gr$GENE[subjectHits(overlaps_filtered)],
intron_length = end(intron_gr)[subjectHits(overlaps_filtered)] - start(intron_gr)[subjectHits(overlaps_filtered)],
stringsAsFactors = FALSE
)
cat("Decoy sites overlapping introns (before gene name filtering):", nrow(matched_intron_coords), "\n")
cat("Unique decoys with intron overlaps (before gene name filtering):", length(unique(matched_intron_coords$decoyID)), "\n")
# Filter to only keep matches where gene name from decoyID matches GENE from PSI table
matched_intron_coords <- matched_intron_coords %>%
filter(gene_from_decoyID == intron_GENE)
